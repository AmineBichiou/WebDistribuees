{
	"info": {
		"name": "User Microservice - Keycloak",
		"description": "Collection pour tester le User Microservice avec Keycloak",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/health",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["health"]
				},
				"description": "Vérifier que le service est actif"
			}
		},
		{
			"name": "2. Créer un utilisateur",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"john.doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
				},
				"url": {
					"raw": "http://localhost:3001/api/users",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users"]
				},
				"description": "Créer un nouvel utilisateur dans Keycloak et MongoDB"
			}
		},
		{
			"name": "3. Récupérer tous les utilisateurs",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/api/users",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users"]
				},
				"description": "Liste tous les utilisateurs depuis Keycloak"
			}
		},
		{
			"name": "4. Récupérer un utilisateur par ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}"]
				},
				"description": "Récupérer un utilisateur avec ses données Keycloak + MongoDB"
			}
		},
		{
			"name": "5. Modifier un utilisateur",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@example.com\"\n}"
				},
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}"]
				},
				"description": "Modifier les informations d'un utilisateur dans Keycloak"
			}
		},
		{
			"name": "6. Récupérer le profil utilisateur",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}/profile",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}", "profile"]
				},
				"description": "Récupérer le profil (stats, préférences) depuis MongoDB"
			}
		},
		{
			"name": "7. Mettre à jour le profil",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"preferences\": {\n    \"language\": \"en\",\n    \"currency\": \"USD\",\n    \"notifications\": {\n      \"email\": true,\n      \"sms\": true\n    }\n  }\n}"
				},
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}/profile",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}", "profile"]
				},
				"description": "Modifier les préférences utilisateur"
			}
		},
		{
			"name": "8. Assigner un rôle",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"roleName\": \"admin\"\n}"
				},
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}/roles",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}", "roles"]
				},
				"description": "Assigner un rôle Keycloak à un utilisateur"
			}
		},
		{
			"name": "9. Récupérer les rôles",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}/roles",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}", "roles"]
				},
				"description": "Liste les rôles d'un utilisateur"
			}
		},
		{
			"name": "10. Supprimer un utilisateur",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/api/users/{userId}",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3001",
					"path": ["api", "users", "{userId}"]
				},
				"description": "Supprimer un utilisateur de Keycloak et MongoDB"
			}
		}
	]
}
