{
	"info": {
		"name": "Keycloak Authentication",
		"description": "Collection pour l'authentification Keycloak et obtention de tokens",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login - Obtenir un Access Token",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "grant_type",
							"value": "password",
							"type": "text"
						},
						{
							"key": "client_id",
							"value": "booking-app",
							"type": "text"
						},
						{
							"key": "username",
							"value": "test.user",
							"type": "text",
							"description": "Votre username Keycloak"
						},
						{
							"key": "password",
							"value": "Password123!",
							"type": "text",
							"description": "Votre mot de passe"
						}
					]
				},
				"url": {
					"raw": "http://localhost:8089/realms/microservices-realm/protocol/openid-connect/token",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8089",
					"path": ["realms", "microservices-realm", "protocol", "openid-connect", "token"]
				},
				"description": "Login avec username/password. Récupérer le access_token de la réponse."
			}
		},
		{
			"name": "2. Refresh Token - Renouveler le token",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "grant_type",
							"value": "refresh_token",
							"type": "text"
						},
						{
							"key": "client_id",
							"value": "booking-app",
							"type": "text"
						},
						{
							"key": "refresh_token",
							"value": "<COLLER_VOTRE_REFRESH_TOKEN_ICI>",
							"type": "text",
							"description": "Le refresh_token obtenu lors du login"
						}
					]
				},
				"url": {
					"raw": "http://localhost:8089/realms/microservices-realm/protocol/openid-connect/token",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8089",
					"path": ["realms", "microservices-realm", "protocol", "openid-connect", "token"]
				},
				"description": "Renouveler le access_token sans re-login"
			}
		},
		{
			"name": "3. Get User Info",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer <COLLER_VOTRE_ACCESS_TOKEN_ICI>",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8089/realms/microservices-realm/protocol/openid-connect/userinfo",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8089",
					"path": ["realms", "microservices-realm", "protocol", "openid-connect", "userinfo"]
				},
				"description": "Récupérer les infos de l'utilisateur connecté via le token"
			}
		},
		{
			"name": "4. Logout",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "client_id",
							"value": "booking-app",
							"type": "text"
						},
						{
							"key": "refresh_token",
							"value": "<COLLER_VOTRE_REFRESH_TOKEN_ICI>",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "http://localhost:8089/realms/microservices-realm/protocol/openid-connect/logout",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8089",
					"path": ["realms", "microservices-realm", "protocol", "openid-connect", "logout"]
				},
				"description": "Se déconnecter et invalider le token"
			}
		},
		{
			"name": "5. [AVEC TOKEN] Créer une réservation",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer <COLLER_VOTRE_ACCESS_TOKEN_ICI>",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"roomId\": 101,\n  \"hotelId\": 1,\n  \"userId\": \"test.user\",\n  \"checkInDate\": \"2026-03-15\",\n  \"checkOutDate\": \"2026-03-20\",\n  \"numberOfGuests\": 2,\n  \"pricePerNight\": 150.00\n}"
				},
				"url": {
					"raw": "http://localhost:8090/api/bookings",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8090",
					"path": ["api", "bookings"]
				},
				"description": "Exemple de requête authentifiée avec le token"
			}
		},
		{
			"name": "6. [AVEC TOKEN] Récupérer mes réservations",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer <COLLER_VOTRE_ACCESS_TOKEN_ICI>",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8090/api/bookings",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8090",
					"path": ["api", "bookings"]
				},
				"description": "Liste des réservations (avec authentification)"
			}
		}
	]
}
